//+------------------------------------------------------------------+
//| SimpleMAEA - example Expert Advisor
//| Opens a BUY order when a fast SMA crosses above a slow SMA
//| and closes it when the fast SMA crosses below the slow SMA.
//+------------------------------------------------------------------+
#property copyright "Generated by Claude Code"
#property link      ""
#property version   "1.00"
#property strict
#include <Trade\Trade.mqh>

//--- input parameters
input int    FastMAPeriod = 10;   // Fast SMA period
input int    SlowMAPeriod = 30;   // Slow SMA period
input double Lots         = 0.1; // Lots per trade
input int    StopLossPips = 20;  // Stop loss in pips
input int    TakeProfitPips = 40; // Take profit in pips

//--- global variables
ulong    eaTicket = 0; // current order ticket

//+------------------------------------------------------------------+
//| Expert initialization function                                   |
//+------------------------------------------------------------------+
int OnInit()
  {
   // nothing to init
   return(INIT_SUCCEEDED);
  }

//+------------------------------------------------------------------+
//| Expert deinitialization function                                 |
//+------------------------------------------------------------------+
void OnDeinit(const int reason)
  {
   // nothing to clean up
  }

//+------------------------------------------------------------------+
//| Expert tick function                                            |
//+------------------------------------------------------------------+
void OnTick()
  {
   // Get the current symbol and timeframe
   string symbol   = _Symbol;
   ENUM_TIMEFRAMES tf = PERIOD_CURRENT;

   // Calculate moving averages
   double fastMA = iMA(symbol, tf, FastMAPeriod, 0, 0, 0);
   double slowMA = iMA(symbol, tf, SlowMAPeriod, 0, 0, 0);

   // Ensure we have valid values
   if(fastMA == 0 || slowMA == 0)
      return;

   // No open position -> look for entry signal
   if(eaTicket == 0)
     {
      if(fastMA > slowMA) // bullish crossover
        {
         // Prepare request
         MqlTradeRequest request;
         MqlTradeResult  result;
         ZeroMemory(request);
         ZeroMemory(result);
         request.action   = TRADE_ACTION_DEAL;
         request.symbol   = symbol;
         request.volume   = Lots;
         request.type     = ORDER_TYPE_BUY;
         request.price    = SymbolInfoDouble(symbol, SYMBOL_ASK);
         request.deviation= 10;
         // Calculate SL/TP in price terms
         double point = (double)SymbolInfoDouble(symbol, SYMBOL_POINT);
         request.sl = request.price - StopLossPips * point;
         request.tp = request.price + TakeProfitPips * point;
         request.magic   = 123456; // arbitrary magic number
         // Send order
         if(!OrderSend(request, result))
            Print("OrderSend failed: ", GetLastError());
         else
           {
            eaTicket = result.order;
            Print("Buy order opened, eaTicket=", eaTicket);
           }
        }
     }
   else // we have an open BUY position
     {
      // Check for exit signal (fast MA crosses below slow MA)
      if(fastMA < slowMA)
        {
         // Close the position
         MqlTradeRequest request;
         MqlTradeResult  result;
         ZeroMemory(request);
         ZeroMemory(result);
         request.action   = TRADE_ACTION_DEAL;
         request.symbol   = symbol;
         request.position = eaTicket;
         request.volume   = Lots;
         request.type     = ORDER_TYPE_SELL; // close BUY with a sell market order
         request.price    = SymbolInfoDouble(symbol, SYMBOL_BID);
         request.deviation= 10;
         request.magic    = 123456;
         if(!OrderSend(request, result))
            Print("Close order failed: ", GetLastError());
         else
           {
            Print("Position closed, eaTicket=", eaTicket);
            eaTicket = 0;
           }
        }
     }
  }
//+------------------------------------------------------------------+